# ==============================================================================
# VS Code & Development Environment
# ==============================================================================
.vscode/
# Exception: If you intentionally want to share your team's launch configurations
# or workspace settings later, uncomment the lines below but ignore files like settings.json:
# !.vscode/launch.json
# !.vscode/tasks.json
*.code-workspace

# Local history extensions
.history/

# ==============================================================================
# Docker Engine & BuildKit Artifacts
# ==============================================================================
# Ignore local container data volumes (never upload databases or live logs)
**/data/
**/logs/
**/*_logs/
**/redis_data/

# Ignore local compose overrides used for testing
docker-compose.override.yml

# Ignore temporary files and system state created by Docker BuildKit
.buildx/
**/.docker/

# Ignore local container status, state logs, or process IDs if generated in-tree
**/*.pid
**/*.sock